# Day 10 Lab - copy thanh .env va dien key can thiet
#   copy .env.example .env

# ChromaDB
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=day10_kb

# Embedding provider
# voyage = stack chinh cua nhom
# local  = fallback khi khong co key
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-multilingual-2
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Freshness SLA (gio)
FRESHNESS_SLA_HOURS=24

# LLM extension: Claudible (Anthropic-compatible)
LLM_PROVIDER=claudible
CLAUDIBLE_API_KEY=
CLAUDIBLE_BASE_URL=https://claudible.io/v1
CLAUDIBLE_MODEL=claude-sonnet-4.6

# Alias tuong thich neu ai quen ten env cua Anthropic
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://claudible.io/v1
